{
  "name": "npm-download-service",
  "version": "1.0.0",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "format": "prettier --write \"src/**/*.{ts,js}\"",
    "start": "tsx --env-file=.env src/index.ts",
    "dev": "tsx watch --env-file=.env src/index.ts"
  },
  "dependencies": {
    "archiver": "^7.0.1",
    "date-fns": "^4.1.0",
    "express": "^5.2.1",
    "semver": "^7.7.1"
  },
  "devDependencies": {
    "@types/archiver": "^7.0.0",
    "@types/express": "^5.0.1",
    "@types/node": "^25.5.0",
    "@types/semver": "^7.5.8",
    "prettier": "3.8.1",
    "tsx": "^4.19.3",
    "typescript": "^6.0.2"
  }
}
